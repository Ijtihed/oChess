# Supabase project credentials
# Get these from https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Sentry crash reporting.
# Sign up at https://sentry.io (free tier is fine for low traffic),
# create a Browser-JavaScript project, copy the DSN. Without this
# unset, the Sentry SDK is never loaded - zero bundle cost.
# VITE_SENTRY_DSN=

# Optional: PostHog product analytics.
# Free tier at https://app.posthog.com - 1M events/month is plenty
# for a hobby chess app. Without this unset, PostHog is never
# loaded. Page views are NOT auto-captured for privacy; named
# events fire from auth + game flows only.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
